<%- layout("/layouts/boilerplate") %>

    <div class="row mt-3 ">
        <h1 class="col-6 offset-3">SignUp on wanderlust</h1>
        <div class="col-6 offset-3">
            <!-- Form -->
            <form action="/signup" method="post" class="needs-validation" novalidate>
                <!-- username -->
                <div class="mb-3">
                    <label for="username" class="form-lable">Username</label>
                    <input name="username" placeholder="magnetic_og" type="text" class="form-control" id="username"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please add a username</div>
                </div>
                <!-- email -->
                 <div class="mb-3">
                    <label for="email" class="form-lable">Email</label>
                    <input name="email" placeholder="magnetic@gmail.com" type="text" class="form-control" id="email"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please add an email</div>
                </div>
                <!-- password -->
                 <div class="mb-3">
                    <label for="password" class="form-lable">Password</label>
                    <input name="password" placeholder="enter a strong password" type="password" class="form-control" id="password"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please add a strong password</div>
                </div>
                <!-- SignUp button -->
                 <button class="btn btn-success">SignUp</button>
            </form>

        </div>
    </div>